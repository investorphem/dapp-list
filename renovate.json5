{
  extends: ['github>valora-inc/renovate-config:default.json5'],
  packageRules: [
    {
      // Disable updates for image-size as 2.x breaks CI
      matchPackageNames: ['image-size'],
      allowedVersions: '<2',
    },
    {
      // Disable major ESLint updates until flat config migration is done
      // ESLint 9+ dropped .eslintrc.* support in favor of eslint.config.js
      // See: https://eslint.org/docs/latest/use/configure/migration-guide
      matchPackageNames: ['eslint'],
      matchUpdateTypes: ['major'],
      enabled: false,
    },
  ],
}
